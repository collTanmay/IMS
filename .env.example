# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================

# DATABASE - Choose ONE of these options:
# Option 1: PlanetScale (Recommended for Vercel)
# DATABASE_URL="mysql://[user]:[password]@[host].us-west-2.psdb.cloud/[database]?sslaccept=strict"

# Option 2: Railway
# DATABASE_URL="mysql://[user]:[password]@[host]:[port]/[database]"

# Option 3: Local Development (localhost)
DATABASE_URL="mysql://root:your_password@localhost:3306/invenflow"

# Next.js Configuration
NODE_ENV="production"
NEXT_PUBLIC_API_URL="https://your-domain.vercel.app"

# Logging
LOG_LEVEL="error"
